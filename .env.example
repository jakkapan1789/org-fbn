# ── Backend connection ──────────────────────────────────────────────────────
# Copy this file to .env (or .env.local) and fill in VITE_API_BASE_URL to point the
# app at a real backend. Leave it empty/unset to keep running standalone against the
# built-in deterministic mock data generator (src/orgchart/orgData.ts) — no backend
# required for local development or demos.

# Base URL the app calls for org-chart data. Include the scheme, no trailing slash —
# e.g. http://localhost:41704/api. The app calls GET {base}/employee/?empNo=<EN>,
# which may return either a bare OrgPerson tree or a full OrgSnapshot (shapes in
# src/orgchart/types.ts); see src/orgchart/api.ts for the exact contract.
VITE_API_BASE_URL=

# Optional: sent as `Authorization: Bearer <token>` on every request to
# VITE_API_BASE_URL. Leave empty if the backend doesn't require it.
VITE_API_TOKEN=

# Optional: abort a request after this many milliseconds (default 10000).
VITE_API_TIMEOUT_MS=10000
